# ── Development auth bypass ─────────────────────────────────
# Set to "true" to skip JWT verification and treat every request
# as ADMIN. NEVER enable this in production.
DEV_SKIP_AUTH=true

# ── Redis / BullMQ (optional) ───────────────────────────────
# Leave REDIS_HOST unset (or commented out) to run imputation
# jobs synchronously without Redis. Set it only if you have
# a Redis server available.
#
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ── App ─────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Azure AD / Entra ID (only needed in production) ─────────
# Leave empty in local dev when DEV_SKIP_AUTH=true
# AZURE_AD_TENANT_ID=<tenant-id>
# AZURE_AD_CLIENT_ID=<client-id>
# AZURE_AD_JWKS_URI=https://login.microsoftonline.com/<tenant-id>/discovery/v2.0/keys
