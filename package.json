{
  "name": "gestor-de-ia",
  "version": "0.0.1",
  "private": true,
  "description": "AI Cost Manager monorepo — Alten",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "dev": "pnpm --parallel --filter @gestor-ia/backend --filter @gestor-ia/frontend dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@typescript-eslint/eslint-plugin": "^7.14.0",
    "@typescript-eslint/parser": "^7.14.0",
    "eslint": "^9.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0"
  }
}
